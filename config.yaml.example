# ─────────────────────────────────────────────────────────────────────────────
# IPTV Relay — config.yaml.example
#
# Copy this file to config.yaml and adjust the values:
#   cp config.yaml.example config.yaml
# ─────────────────────────────────────────────────────────────────────────────

server:
  host:  "0.0.0.0"   # listen on all interfaces; use 127.0.0.1 for local-only
  port:  8080
  token: "changeme"  # pick a random long string — embedded in the playlist URL

# ─────────────────────────────────────────────────────────────────────────────
# Option A: streams defined directly in this config (key 1-8 selects the stream)
# ─────────────────────────────────────────────────────────────────────────────
streams:
  1:
    name: "Channel One"
    url:  "http://iptv.example.com/ch1/stream.m3u8"
  2:
    name: "Channel Two"
    url:  "http://iptv.example.com/ch2/stream.m3u8"
  3:
    name: "Channel Three"
    url:  "http://iptv.example.com/ch3/stream.m3u8"
  4:
    name: "Sports HD"
    url:  "http://iptv.example.com/sports/stream"
  5:
    name: "News 24"
    url:  "http://iptv.example.com/news/stream"
  6:
    name: "Movies Plus"
    url:  "http://iptv.example.com/movies/stream"
  7:
    name: "Kids TV"
    url:  "http://iptv.example.com/kids/stream"
  8:
    name: "Documentary"
    url:  "http://iptv.example.com/docs/stream"

# ─────────────────────────────────────────────────────────────────────────────
# Option B: load streams from a .m3u file
# If m3u_file is set, the `streams` above are ignored.
# ─────────────────────────────────────────────────────────────────────────────
# m3u_file: "channels.m3u"
